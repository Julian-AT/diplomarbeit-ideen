# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# https://qdrant.tech/documentation/cloud/
QDRANT_URL=****
QDRANT_API_KEY=****
QDRANT_COLLECTION=thesis_ideas

# https://ai.google.dev/gemini-api/docs
GEMINI_API_KEY=****
GEMINI_CHAT_MODEL=gemini-3.5-flash

# https://ai.google.dev/gemini-api/docs/embeddings
# Phase 1 approved multimodal evaluation first; use gemini-embedding-001 if text-only extraction wins later.
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# Optional: enables Vercel AI Gateway models in the selector. When present, Sonnet 5 is the active default.
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=****
GATEWAY_CHAT_MODEL=anthropic/claude-sonnet-5
